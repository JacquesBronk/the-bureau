{
  "name": "the-bureau",
  "version": "1.0.0",
  "description": "Multi-agent orchestration for Claude Code via Redis streams and MCP",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JacquesBronk/the-bureau.git"
  },
  "homepage": "https://github.com/JacquesBronk/the-bureau#readme",
  "bugs": {
    "url": "https://github.com/JacquesBronk/the-bureau/issues"
  },
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "the-bureau": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && npm run bundle",
    "build:tsc": "tsc",
    "bundle": "bash scripts/bundle.sh",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reportOnFailure",
    "test:e2e": "vitest run tests/e2e/ --testTimeout 30000",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "test:sentinel": "SENTINEL_TEST=1 vitest run tests/redis-sentinel.test.ts",
    "release": "echo 'Release: npm version <patch|minor|major> && git push --follow-tags'"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.214.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@types/jsonwebtoken": "^9.0.10",
    "ioredis": "^5.6.0",
    "jose": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "uuid": "^11.1.0",
    "yaml": "^2.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/pino": "^7.0.4",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
