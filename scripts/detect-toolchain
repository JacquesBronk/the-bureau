#!/usr/bin/env node
// detect-toolchain [dir]
// Prints a draft bureau.buildconfig.json to stdout (exit 0) when detection is confident.
// Prints reason(s) to stderr and exits 1 when detection is non-confident.
//
// NOTE: This file intentionally re-implements src/buildconfig/detect.ts in plain JS
// so it can run without a build step (dependency-free Node). Keep both in sync when
// adding new language/manifest rules.
import { readdirSync, readFileSync, statSync } from 'node:fs';
import { join, relative } from 'node:path';

const LANGUAGE_MAP = {
  'package.json': 'node',
  'pyproject.toml': 'python',
  'requirements.txt': 'python',
  'setup.py': 'python',
  'go.mod': 'go',
  'Cargo.toml': 'rust',
  'pom.xml': 'java',
  'build.gradle': 'java',
  'build.gradle.kts': 'java',
  'Gemfile': 'ruby',
  'composer.json': 'php',
  'CMakeLists.txt': 'cpp',
  'Package.swift': 'swift',
  'mix.exs': 'elixir',
};

const EXTENSION_MAP = {
  '.py': 'python', '.cs': 'dotnet', '.go': 'go', '.rs': 'rust',
  '.cpp': 'cpp', '.cc': 'cpp', '.hpp': 'cpp', '.rb': 'ruby',
  '.php': 'php', '.ts': 'node', '.js': 'node', '.mjs': 'node',
};

const TOOLCHAIN_MAP = { node: 'node', python: 'python', dotnet: 'dotnet' };

const IGNORE_DIRS = new Set([
  '.git', 'node_modules', 'dist', 'build', 'target', 'bin', 'obj',
  'vendor', '.venv', 'venv', '__pycache__', 'coverage', '.next', 'out',
]);

function resolveManifestLanguage(filename) {
  if (LANGUAGE_MAP[filename]) return LANGUAGE_MAP[filename];
  if (filename.endsWith('.csproj') || filename.endsWith('.sln')) return 'dotnet';
  return undefined;
}

function parsePackageJsonCommands(content) {
  if (!content) return { commands: {}, trusted: false };
  let parsed;
  try { parsed = JSON.parse(content); } catch { return { commands: {}, trusted: false }; }
  if (typeof parsed !== 'object' || parsed === null) return { commands: {}, trusted: false };
  const commands = {};
  const scripts = parsed.scripts;
  if (typeof scripts === 'object' && scripts !== null) {
    if (typeof scripts.test === 'string') commands.test = scripts.test;
  }
  return { commands, trusted: true };
}

function parseManifestCommands(language, manifestPath) {
  if (language !== 'node') {
    let content;
    try { content = readFileSync(manifestPath, 'utf8'); } catch { return { commands: {}, trusted: false }; }
    if (!content) return { commands: {}, trusted: false };
    return { commands: {}, trusted: true };
  }
  let content;
  try { content = readFileSync(manifestPath, 'utf8'); } catch { return { commands: {}, trusted: false }; }
  return parsePackageJsonCommands(content);
}

function analyzeDir(dirPath, entries) {
  const manifestsByLanguage = new Map();
  for (const entry of entries) {
    const lang = resolveManifestLanguage(entry);
    if (lang && !manifestsByLanguage.has(lang)) {
      manifestsByLanguage.set(lang, join(dirPath, entry));
    }
  }
  return { manifestsByLanguage };
}

function toServicePath(rootDir, absDir) {
  if (absDir === rootDir) return '.';
  return './' + relative(rootDir, absDir);
}

function walkTree(rootDir, currentDir, serviceMap, extCounts) {
  let entries;
  try { entries = readdirSync(currentDir); } catch { return; }
  const files = [], subdirs = [];
  for (const entry of entries) {
    if (IGNORE_DIRS.has(entry)) continue;
    const fullPath = join(currentDir, entry);
    let stat;
    try { stat = statSync(fullPath); } catch { continue; }
    if (stat.isDirectory()) subdirs.push(entry);
    else files.push(entry);
  }
  for (const file of files) {
    const dot = file.lastIndexOf('.');
    if (dot !== -1) {
      const ext = file.slice(dot);
      if (EXTENSION_MAP[ext]) extCounts.set(ext, (extCounts.get(ext) ?? 0) + 1);
    }
  }
  const analysis = analyzeDir(currentDir, files);
  if (analysis.manifestsByLanguage.size > 0) serviceMap.set(currentDir, analysis);
  for (const sub of subdirs) walkTree(rootDir, join(currentDir, sub), serviceMap, extCounts);
}

function buildServiceFromAnalysis(servicePath, analysis) {
  const langs = [...analysis.manifestsByLanguage.keys()];
  if (langs.length > 1) {
    return { path: servicePath, commands: {}, commandsTrusted: false, verdict: 'ambiguous',
      reason: `conflicting manifests for languages: ${langs.join(', ')}` };
  }
  const language = langs[0];
  const manifestPath = analysis.manifestsByLanguage.get(language);
  const toolchain = TOOLCHAIN_MAP[language];
  if (!toolchain) {
    return { path: servicePath, language, commands: {}, commandsTrusted: false,
      verdict: 'unsupported', reason: `language ${language} has no supported toolchain` };
  }
  const { commands, trusted } = parseManifestCommands(language, manifestPath);
  return { path: servicePath, language, toolchain, commands, commandsTrusted: trusted,
    verdict: 'confident', reason: `manifest ${manifestPath.split('/').pop()} detected ${language}` };
}

function detectToolchains(dir) {
  const serviceMap = new Map();
  const extCounts = new Map();
  walkTree(dir, dir, serviceMap, extCounts);

  if (serviceMap.size > 0) {
    const services = [];
    for (const [absDir, analysis] of serviceMap) {
      services.push(buildServiceFromAnalysis(toServicePath(dir, absDir), analysis));
    }
    const confident = services.every(s => s.verdict === 'confident' && s.commandsTrusted);
    return { services, confident };
  }

  if (extCounts.size === 0) {
    return { services: [{ path: '.', commands: {}, commandsTrusted: false, verdict: 'unidentified',
      reason: 'no language signal found' }], confident: false };
  }

  const langCounts = new Map();
  for (const [ext, count] of extCounts) {
    const lang = EXTENSION_MAP[ext];
    langCounts.set(lang, (langCounts.get(lang) ?? 0) + count);
  }
  const sorted = [...langCounts.entries()].sort((a, b) => b[1] - a[1]);
  const [topLang, topCount] = sorted[0];
  const runnerUp = sorted[1]?.[1] ?? 0;
  if (topCount >= 2 * (runnerUp || 1) || runnerUp === 0) {
    return { services: [{ path: '.', language: topLang, toolchain: TOOLCHAIN_MAP[topLang],
      commands: {}, commandsTrusted: false, verdict: 'confident',
      reason: `extension histogram dominant: ${topLang}` }], confident: false };
  }
  return { services: [{ path: '.', commands: {}, commandsTrusted: false, verdict: 'unidentified',
    reason: 'no dominant language in extension histogram' }], confident: false };
}

// --- CLI ---
const dir = process.argv[2] ?? '.';
const result = detectToolchains(dir);

if (!result.confident) {
  for (const svc of result.services) {
    process.stderr.write(`${svc.path}: ${svc.verdict}: ${svc.reason}\n`);
  }
  process.exit(1);
}

const services = result.services.map(svc => {
  const out = { name: svc.path, path: svc.path, language: svc.language };
  if (svc.toolchain) out.toolchain = svc.toolchain;
  if (svc.commandsTrusted) {
    if (svc.commands.test) out.test = svc.commands.test;
  }
  return out;
});

process.stdout.write(JSON.stringify({ version: 1, services }) + '\n');
